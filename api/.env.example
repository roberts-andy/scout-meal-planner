# Microsoft Identity Platform — JWT validation for /consumers endpoint
ENTRA_CLIENT_ID=your-client-id
APPINSIGHTS_CONNECTION_STRING=

# Cosmos DB (set by Azure infra for deployed environments)
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_DATABASE=scout-meal-planner

# Azure Communication Services email delivery (required for shopping list email endpoint)
# ACS_ENDPOINT=acs-scout-meal-planner.unitedstates.communication.azure.com
# ACS_FROM_EMAIL=DoNotReply@your-acs-domain.azurecomm.net

# Feature flags (optional overrides). FEATURE_FLAGS_ENV defaults to dev.
# FEATURE_FLAGS_ENV=dev # dev|beta|prod
# FEATURE_FLAG_ENABLE_CONTENT_MODERATION=false
# FEATURE_FLAG_ENABLE_EMAIL_SHOPPING_LIST=false
# FEATURE_FLAG_ENABLE_SHARED_LINKS=false
# FEATURE_FLAG_ENABLE_FEEDBACK=false
# FEATURE_FLAG_ENABLE_PRINT_RECIPES=true
