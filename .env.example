# Frontend — leave blank to use the Vite/SWA CLI proxy for /api
VITE_API_URL=

# Microsoft Identity Platform — Personal Microsoft Accounts (/consumers endpoint)
# Get the client ID from your Entra app registration (Azure portal)
VITE_ENTRA_CLIENT_ID=your-client-id

# Azure Functions (api/) — Cosmos DB
# For the local emulator, use the well-known connection string from:
# https://learn.microsoft.com/en-us/azure/cosmos-db/emulator#authentication
COSMOS_CONNECTION_STRING=AccountEndpoint=https://localhost:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
# For a remote Cosmos DB account, replace the above with your real connection string.
# COSMOS_DATABASE=scout-meal-planner

# Accept the emulator's self-signed TLS cert (set to 1 for emulator, remove for production)
NODE_TLS_REJECT_UNAUTHORIZED=0
